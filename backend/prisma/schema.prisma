generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Icon {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  label     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  category  Category[]
  links     Link[]
}

model Category {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  iconName  String
  colorHex  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  icon      Icon     @relation(fields: [iconName], references: [name])
  links     Link[]

  @@index([iconName])
}

model Link {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  name       String
  url        String
  desc       String   @default("")
  iconName   String
  status     Status   @default(online)
  permit     Permit   @default(external)
  categoryId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])
  icon       Icon     @relation(fields: [iconName], references: [name])

  @@unique([name, categoryId])
  @@index([iconName])
  @@index([categoryId])
  @@index([permit])
}

model CaseDetail {
  id                   Int       @id @default(autoincrement())
  caseReference        String?   @map("case_reference") @db.VarChar(50)
  caseNumber           String?   @map("case_number") @db.VarChar(20)
  nextStageDate        DateTime? @map("next_stage_date") @db.Date
  nextStage            String?   @map("next_stage") @db.VarChar(50)
  filingDate           DateTime? @map("filing_date") @db.Date
  caseParties          String?   @map("case_parties")
  judge                String?   @db.VarChar(200)
  courtLevel           String?   @map("court_level") @db.VarChar(50)
  court                String?   @db.VarChar(100)
  caseSubtype          String?   @map("case_subtype") @db.VarChar(100)
  caseStatus           String?   @map("case_status") @db.VarChar(20)
  decidedBy            String?   @map("decided_by") @db.VarChar(200)
  decisionDate         DateTime? @map("decision_date") @db.Date
  mediatorName         String?   @map("mediator_name") @db.VarChar(200)
  mediationCloseStatus String?   @map("mediation_close_status") @db.VarChar(50)
  assignmentStatus     String?   @map("assignment_status") @db.VarChar(20)
  panelAssignment      String?   @map("panel_assignment")
  createdAt            DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([caseNumber], map: "idx_case_number")
  @@index([caseReference], map: "idx_case_reference")
  @@index([caseStatus], map: "idx_case_status")
  @@index([court], map: "idx_court")
  @@map("case_details")
}

model primary_courts {
  id                           Int       @id @default(autoincrement())
  namba_ya_shauri_ya_marejeo   String?   @db.VarChar(100)
  mahakama                     String?   @db.VarChar(200)
  namba_ya_shauri              String?   @db.VarChar(50)
  mwaka_wa_shauri_kufungulilwa Int?
  aina_ya_shauri               String?   @db.VarChar(50)
  wadaawa                      String?
  wilaya                       String?   @db.VarChar(100)
  kanda                        String?   @db.VarChar(100)
  hakimu                       String?   @db.VarChar(200)
  status                       String?   @db.VarChar(20)
  hali_ya_muonekano            String?   @db.VarChar(50)
  umri_wa_shauri               Int?
  backlog_status               String?   @db.VarChar(20)
  tarehe_ya_kufungua_shauri    DateTime? @db.Date
  tarehe_ya_kuisha_shauri      DateTime? @db.Date
  mwaka_wa_shauri_kuisha       Int?
  mwezi_wa_shauri_kuisha       Int?
  time_taken                   Int?
  created_at                   DateTime? @db.Timestamp(6)
  updated_at                   DateTime? @db.Timestamp(6)

  @@index([namba_ya_shauri], map: "idx_primary_case_number")
  @@index([namba_ya_shauri_ya_marejeo], map: "idx_primary_case_reference")
  @@index([mahakama], map: "idx_primary_court")
  @@index([tarehe_ya_kufungua_shauri], map: "idx_primary_filing_date")
  @@index([status], map: "idx_primary_status")
}

enum Permit {
  internal
  external
}

enum Status {
  online
  degraded
}
